# =============================================================================
#  Quorum - environment configuration
#  Copy this file to `.env` and fill in the values you need.
#      cp .env.example .env
#  .env is git-ignored; never commit real keys.
# =============================================================================

# --- Which mode does the backend run in? -------------------------------------
#   demo  -> fully offline, no LLM key needed. Runs a scripted deliberation
#            that still calls the real coded tools. Best for building the UI
#            and recording the demo video.
#   live  -> connects to a running neuro-san server (real LLM agents).
BACKEND_MODE=demo

# --- LLM provider key (only ONE is required, and only for live mode) ---------
# neuro-san reads these directly from the environment. Uncomment the provider
# you have access to. The hackathon default is Mistral (key from admin.mistral.ai).
# MISTRAL_API_KEY=your_mistral_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Model name must match your provider (mirror this in registries/quorum.hocon):
#   Mistral   -> mistral-large-latest
#   OpenAI    -> gpt-4o
#   Anthropic -> claude-3-5-sonnet-latest
LLM_MODEL_NAME=mistral-large-latest

# --- neuro-san server target (used when BACKEND_MODE=live) -------------------
NEURO_SAN_SERVER_HOST=localhost
NEURO_SAN_SERVER_PORT=30011
AGENT_NETWORK_NAME=quorum

# --- Web app ------------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
CORS_ORIGINS=*
